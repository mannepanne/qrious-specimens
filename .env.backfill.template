# Template for scripts/backfill-broken-specimens.ts
#
# Copy to .env.backfill and fill in real values, then run:
#   env $(cat .env.backfill) bun run scripts/backfill-broken-specimens.ts
#
# Get the same values that are set as Wrangler secrets:
#   - SUPABASE_URL: Supabase dashboard → Project Settings → API → Project URL
#   - SUPABASE_SERVICE_ROLE_KEY: Supabase dashboard → Project Settings → API → service_role key
#   - GEMINI_API_KEY: Google AI Studio → API Keys
#   - ANTHROPIC_API_KEY: Anthropic Console → API Keys
#   - CF_ACCOUNT_ID: Cloudflare dashboard → right sidebar → Account ID
#   - CF_IMAGES_TOKEN: Cloudflare → My Profile → API Tokens (Images:Edit permission)
#   - CF_IMAGES_DELIVERY_HASH: from wrangler.toml [vars] (not a secret)
#
# NEVER commit .env.backfill — it's in .gitignore via the .env.* pattern.

